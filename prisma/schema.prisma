generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Client {
  id         String    @id @default(cuid())
  name       String
  firstName  String?
  lastName   String?
  clientType String    @default("Particulier")
  email      String?
  phone      String
  address    String?
  zipCode    String?
  city       String?
  createdAt  DateTime  @default(now())
  siret      String?
  vatNumber  String?
  invoices   Invoice[]
  quotes     Quote[]
  repairs    Repair[]
}

model Quote {
  id         String    @id @default(cuid())
  number     String    @unique
  status     String    @default("BROUILLON")
  clientId   String
  repairId   String?
  items      String
  totalHT    Float
  totalTTC   Float
  notes      String?
  validUntil DateTime?
  invoiceId  String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  taxDetails String?
  invoice    Invoice?  @relation("QuoteToInvoice", fields: [invoiceId], references: [id])
  repair     Repair?   @relation(fields: [repairId], references: [id])
  client     Client    @relation(fields: [clientId], references: [id])
}

model Invoice {
  id         String   @id @default(cuid())
  number     String   @unique
  clientId   String
  repairId   String?
  items      String
  totalHT    Float
  totalTTC   Float
  notes      String?
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  taxDetails String?
  repair     Repair?  @relation(fields: [repairId], references: [id])
  client     Client   @relation(fields: [clientId], references: [id])
  quote      Quote?   @relation("QuoteToInvoice")
}

model DeviceType {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  models    DeviceModel[]
}

model DeviceBrand {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  models    DeviceModel[]
}

model DeviceModel {
  id             String      @id @default(cuid())
  name           String
  brandId        String
  typeId         String
  createdAt      DateTime    @default(now())
  modelReference String?
  type           DeviceType  @relation(fields: [typeId], references: [id])
  brand          DeviceBrand @relation(fields: [brandId], references: [id])
  parts          Part[]
  services       Service[]

  @@unique([name, brandId])
}

model Part {
  id          String       @id @default(cuid())
  name        String
  sku         String       @unique
  costPrice   Float
  stock       Int          @default(0)
  minStock    Int          @default(0)
  supplier    String?
  supplierRef String?
  location    String?
  description String?
  modelId     String?
  createdAt   DateTime     @default(now())
  quality     String?
  model       DeviceModel? @relation(fields: [modelId], references: [id])
  services    Service[]
}

model Service {
  id             String          @id @default(cuid())
  name           String
  laborCost      Float
  suggestedPrice Float           @default(0)
  duration       Int             @default(30)
  partId         String?
  modelId        String?
  description    String?
  createdAt      DateTime        @default(now())
  repairs        RepairService[]
  model          DeviceModel?    @relation(fields: [modelId], references: [id])
  part           Part?           @relation(fields: [partId], references: [id])
}

model Repair {
  id         String          @id @default(cuid())
  status     String          @default("PENDING")
  partStatus String          @default("IN_STOCK")
  clientId   String
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  invoices   Invoice[]
  quotes     Quote[]
  client     Client          @relation(fields: [clientId], references: [id])
  logs       RepairLog[]
  services   RepairService[]
}

model RepairService {
  id          String  @id @default(cuid())
  repairId    String
  serviceId   String
  quantity    Int     @default(1)
  priceAtTime Float
  service     Service @relation(fields: [serviceId], references: [id])
  repair      Repair  @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model RepairLog {
  id        String   @id @default(cuid())
  repairId  String
  status    String
  comment   String?
  createdAt DateTime @default(now())
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model ShopProduct {
  id            String   @id @default(cuid())
  name          String
  category      String
  sku           String?  @unique
  barcode       String?  @unique
  purchasePrice Float
  sellingPrice  Float
  stock         Int      @default(0)
  minStock      Int      @default(2)
  supplier      String?
  description   String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkshopSettings {
  id          String   @id @default("singleton")
  name        String   @default("MOMUY&TECH SAS")
  address     String   @default("123 Avenue de la Réparation")
  zipCode     String   @default("75001")
  city        String   @default("Paris")
  countryCode String   @default("FR")
  phone       String   @default("01 23 45 67 89")
  email       String   @default("contact@momuytech.fr")
  siret       String   @default("12345678901234")
  vatNumber   String   @default("FR12345678901")
  legalForm   String   @default("SAS")
  capital     String   @default("1000€")
  rcs         String   @default("Paris B 123 456 789")
  iban        String?
  bic         String?
  updatedAt   DateTime @updatedAt
}
