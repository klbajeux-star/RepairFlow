// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id      String   @id @default(cuid())
  name    String
  email   String?
  phone   String
  repairs Repair[]
  createdAt DateTime @default(now())
}

model Part {
  id          String    @id @default(cuid())
  name        String
  sku         String    @unique
  costPrice   Float     // Prix d'achat de la pièce
  stock       Int       @default(0)
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
}

model Service {
  id          String   @id @default(cuid())
  name        String   // Ex: "Remplacement écran iPhone 13"
  laborCost   Float    // Main d'oeuvre pure
  partId      String?  // Pièce associée optionnelle
  part        Part?    @relation(fields: [partId], references: [id])
  description String?
  repairs     RepairService[]
  createdAt   DateTime @default(now())
}

model Repair {
  id          String   @id @default(cuid())
  status      String   @default("PENDING") // PENDING, DIAGNOSIS, IN_PROGRESS, READY, DELIVERED, CANCELLED
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  services    RepairService[]
  logs        RepairLog[]
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RepairService {
  id        String  @id @default(cuid())
  repairId  String
  serviceId String
  repair    Repair  @relation(fields: [repairId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])
  quantity  Int     @default(1)
  priceAtTime Float // Prix total (pièce + MO) fixé au moment de l'édition du ticket
}

model RepairLog {
  id        String   @id @default(cuid())
  repairId  String
  repair    Repair   @relation(fields: [repairId], references: [id])
  status    String
  comment   String?
  createdAt DateTime @default(now())
}
